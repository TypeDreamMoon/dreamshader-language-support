{
  "name": "dreamshaderlang-language-support",
  "displayName": "DreamShaderLang Language Support",
  "description": "Language support for DreamShaderLang .dsm material files and .dsh shared headers.",
  "version": "1.2.19",
  "publisher": "typedreammoon",
  "author": {
    "name": "TypeDreamMoon",
    "url": "https://github.com/TypeDreamMoon"
  },
  "homepage": "https://dev.64hz.cn",
  "repository": {
    "type": "git",
    "url": "https://github.com/TypeDreamMoon/dreamshader-language-support"
  },
  "license": "MIT",
  "copyright": "Copyright (c) 2026 TypeDreamMoon. All rights reserved.",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "dreamshaderlang",
    "dreamshader",
    "shader",
    "package",
    "unreal",
    "material",
    "dsm",
    "dsh"
  ],
  "activationEvents": [
    "onLanguage:dreamshaderlang",
    "onView:dreamshader.bridgeDiagnostics",
    "onCommand:dreamshader.showBridgeDiagnostics",
    "onCommand:dreamshader.recompileCurrent",
    "onCommand:dreamshader.recompileAll",
    "onCommand:dreamshader.refreshBridgeDiagnostics",
    "onCommand:dreamshader.openBridgeDiagnosticLocation",
    "onCommand:dreamshader.cleanGeneratedShaders",
    "onCommand:dreamshader.installPackageFromGitHub",
    "onCommand:dreamshader.browsePackages",
    "onCommand:dreamshader.updatePackages",
    "onCommand:dreamshader.removePackage",
    "onCommand:dreamshader.packageUninstall",
    "onCommand:dreamshader.openPackagesFolder",
    "onCommand:dreamshader.addPackageStoreIndex",
    "onCommand:dreamshader.removePackageStoreIndex",
    "onCommand:dreamshader.createPackage",
    "onCommand:dreamshader.createMaterial",
    "onCommand:dreamshader.createHeader",
    "onCommand:dreamshader.createTextureSample",
    "onCommand:dreamshader.createNoiseMaterial"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dreamshader.showBridgeDiagnostics",
        "title": "DreamShaderLang: Show Bridge Panel",
        "icon": "$(pulse)"
      },
      {
        "command": "dreamshader.recompileCurrent",
        "title": "DreamShaderLang: Recompile Current Source",
        "icon": "$(play)"
      },
      {
        "command": "dreamshader.recompileAll",
        "title": "DreamShaderLang: Recompile All DSM",
        "icon": "$(sync)"
      },
      {
        "command": "dreamshader.cleanGeneratedShaders",
        "title": "DreamShaderLang: Clean Generated Shaders",
        "icon": "$(trash)"
      },
      {
        "command": "dreamshader.refreshBridgeDiagnostics",
        "title": "DreamShaderLang: Refresh Bridge Diagnostics",
        "icon": "$(refresh)"
      },
      {
        "command": "dreamshader.openBridgeDiagnosticLocation",
        "title": "DreamShaderLang: Open Bridge Diagnostic",
        "icon": "$(link-external)"
      },
      {
        "command": "dreamshader.installPackageFromGitHub",
        "title": "DreamShaderLang: Install Package from GitHub",
        "icon": "$(cloud-download)"
      },
      {
        "command": "dreamshader.browsePackages",
        "title": "DreamShaderLang: Browse Package Store",
        "icon": "$(package)"
      },
      {
        "command": "dreamshader.updatePackages",
        "title": "DreamShaderLang: Update Installed Packages",
        "icon": "$(sync)"
      },
      {
        "command": "dreamshader.removePackage",
        "title": "DreamShaderLang: Remove Installed Package",
        "icon": "$(trash)"
      },
      {
        "command": "dreamshader.packageUninstall",
        "title": "DreamShaderLang: Package Uninstall",
        "icon": "$(trash)"
      },
      {
        "command": "dreamshader.openPackagesFolder",
        "title": "DreamShaderLang: Open Packages Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "dreamshader.addPackageStoreIndex",
        "title": "DreamShaderLang: Add Package Store Index Source",
        "icon": "$(add)"
      },
      {
        "command": "dreamshader.removePackageStoreIndex",
        "title": "DreamShaderLang: Remove Package Store Index Source",
        "icon": "$(remove)"
      },
      {
        "command": "dreamshader.createPackage",
        "title": "DreamShaderLang: Create Package Step by Step",
        "icon": "$(package)"
      },
      {
        "command": "dreamshader.createMaterial",
        "title": "DreamShaderLang: Create DreamShader Material",
        "icon": "$(new-file)"
      },
      {
        "command": "dreamshader.createHeader",
        "title": "DreamShaderLang: Create DreamShader Header",
        "icon": "$(file-code)"
      },
      {
        "command": "dreamshader.createTextureSample",
        "title": "DreamShaderLang: Create DreamShader Texture Sample",
        "icon": "$(file-media)"
      },
      {
        "command": "dreamshader.createNoiseMaterial",
        "title": "DreamShaderLang: Create DreamShader Noise Material",
        "icon": "$(symbol-event)"
      }
    ],
    "languages": [
      {
        "id": "dreamshaderlang",
        "aliases": [
          "DreamShaderLang",
          "dreamshaderlang",
          "DreamShader",
          "dreamshader",
          "dsm",
          "dsh"
        ],
        "extensions": [
          ".dsm",
          ".dsh"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dreamshaderlang",
        "scopeName": "source.dreamshaderlang",
        "path": "./syntaxes/dreamshader.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "dreamshaderlang",
        "path": "./snippets/dreamshader.code-snippets"
      }
    ],
    "configuration": {
      "title": "DreamShaderLang",
      "properties": {
        "dreamshader.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Optional Unreal project root used for DreamShaderLang bridge files. Leave empty to auto-detect from the active .dsm/.dsh file or workspace."
        },
        "dreamshader.packageStoreIndexUrls": {
          "type": "array",
          "default": [
            "https://raw.githubusercontent.com/TypeDreamMoon/dreamshader-package-index/main/packages.json"
          ],
          "items": {
            "type": "string"
          },
          "description": "Package store index sources. Each source should be a packages.json URL or local file path."
        },
        "dreamshader.packageStoreIndexUrl": {
          "type": "string",
          "default": "https://raw.githubusercontent.com/TypeDreamMoon/dreamshader-package-index/main/packages.json",
          "description": "Deprecated single package store index URL. Prefer dreamshader.packageStoreIndexUrls."
        },
        "dreamshader.enableGitHubPackageSearch": {
          "type": "boolean",
          "default": true,
          "description": "Include public GitHub repositories tagged with dreamshader-package when browsing DreamShader packages."
        },
        "dreamshader.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the DreamShaderLang status bar item for the active .dsm/.dsh document."
        },
        "dreamshader.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show DreamShaderLang CodeLens actions such as Recompile Current / Recompile All above Shader and ShaderFunction blocks."
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "dreamshader.bridge",
          "title": "DreamShader Bridge",
          "icon": "resources/dreamshader-bridge.svg"
        }
      ]
    },
    "views": {
      "dreamshader.bridge": [
        {
          "id": "dreamshader.bridgeDiagnostics",
          "name": "Diagnostics"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "dreamshader.recompileCurrent",
          "when": "resourceLangId == dreamshaderlang",
          "group": "navigation@1"
        },
        {
          "command": "dreamshader.browsePackages",
          "when": "resourceLangId == dreamshaderlang",
          "group": "navigation@2"
        },
        {
          "command": "dreamshader.cleanGeneratedShaders",
          "when": "resourceLangId == dreamshaderlang",
          "group": "navigation@3"
        },
        {
          "command": "dreamshader.showBridgeDiagnostics",
          "when": "resourceLangId == dreamshaderlang",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "command": "dreamshader.recompileCurrent",
          "when": "resourceLangId == dreamshaderlang",
          "group": "navigation@1"
        },
        {
          "command": "dreamshader.cleanGeneratedShaders",
          "when": "resourceLangId == dreamshaderlang",
          "group": "navigation@2"
        }
      ],
      "view/title": [
        {
          "command": "dreamshader.refreshBridgeDiagnostics",
          "when": "view == dreamshader.bridgeDiagnostics",
          "group": "navigation@1"
        },
        {
          "command": "dreamshader.recompileAll",
          "when": "view == dreamshader.bridgeDiagnostics",
          "group": "navigation@2"
        },
        {
          "command": "dreamshader.cleanGeneratedShaders",
          "when": "view == dreamshader.bridgeDiagnostics",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "dreamshader.openBridgeDiagnosticLocation",
          "when": "view == dreamshader.bridgeDiagnostics && viewItem == dreamshaderBridgeFile",
          "group": "inline@1"
        },
        {
          "command": "dreamshader.openBridgeDiagnosticLocation",
          "when": "view == dreamshader.bridgeDiagnostics && viewItem == dreamshaderBridgeDiagnostic",
          "group": "inline@1"
        },
        {
          "command": "dreamshader.openBridgeDiagnosticLocation",
          "when": "view == dreamshader.bridgeDiagnostics && viewItem == dreamshaderBridgeMeta",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2"
  }
}
