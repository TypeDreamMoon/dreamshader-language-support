{
  "name": "dreamshaderlang-language-support",
  "displayName": "DreamShaderLang Language Support",
  "description": "Language support for DreamShaderLang .dsm material files and .dsh shared headers.",
  "version": "1.0.0",
  "publisher": "typedreammoon",
  "author": {
    "name": "TypeDreamMoon",
    "url": "https://github.com/TypeDreamMoon"
  },
  "homepage": "https://dev.64hz.cn",
  "repository": {
    "type": "git",
    "url": "https://github.com/TypeDreamMoon"
  },
  "license": "MIT",
  "copyright": "Copyright (c) 2026 TypeDreamMoon. All rights reserved.",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "dreamshaderlang",
    "dreamshader",
    "shader",
    "unreal",
    "material",
    "dsm",
    "dsh"
  ],
  "activationEvents": [
    "onLanguage:dreamshaderlang",
    "onCommand:dreamshader.recompileCurrent",
    "onCommand:dreamshader.recompileAll"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dreamshader.recompileCurrent",
        "title": "DreamShaderLang: Recompile Current Source"
      },
      {
        "command": "dreamshader.recompileAll",
        "title": "DreamShaderLang: Recompile All DSM"
      }
    ],
    "languages": [
      {
        "id": "dreamshaderlang",
        "aliases": [
          "DreamShaderLang",
          "dreamshaderlang",
          "DreamShader",
          "dreamshader",
          "dsm",
          "dsh"
        ],
        "extensions": [
          ".dsm",
          ".dsh"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dreamshaderlang",
        "scopeName": "source.dreamshaderlang",
        "path": "./syntaxes/dreamshader.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "dreamshaderlang",
        "path": "./snippets/dreamshader.code-snippets"
      }
    ],
    "configuration": {
      "title": "DreamShaderLang",
      "properties": {
        "dreamshader.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Optional Unreal project root used for DreamShaderLang bridge files. Leave empty to auto-detect from the active .dsm/.dsh file or workspace."
        }
      }
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2"
  }
}
